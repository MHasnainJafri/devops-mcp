# Normalize all text files to LF in the repo and on checkout.
# The bin entry (dist/index.js, built from src/index.ts) starts with a
# "#!/usr/bin/env node" shebang — a CRLF there breaks execution on
# Linux/macOS ("env: node\r: No such file or directory").
* text=auto eol=lf

# Windows scripts that genuinely need CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.pem binary
