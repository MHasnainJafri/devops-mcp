{
  "name": "devops-mcp",
  "version": "1.0.0",
  "type": "module",
  "description": "Mode-based DevOps MCP server for AI agents — SAFE-only discovery, gated elevation, production write-gate.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "devops-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "config/_example",
    "config/servers.example.json",
    "config/servers.schema.json",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest",
    "test:run": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "devops",
    "automation",
    "server-provisioning",
    "ai-tools"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dockerode": "^4.0.2",
    "ssh2": "^1.15.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/dockerode": "^4.0.1",
    "@types/node": "^20.10.0",
    "@types/ssh2": "^1.11.19",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
